# Postgres connection (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/urlshortener

# Redis connection
REDIS_URL=redis://localhost:6379/0

# Base URL used when building the short link returned by /shorten
BASE_URL=http://localhost:8000

# How long (seconds) a resolved short code stays cached in Redis
CACHE_TTL=3600

# IP rate limit on the shorten endpoint: MAX requests per WINDOW seconds
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60

# Offset applied to the row id before base62 encoding so codes start a few chars long
ID_OFFSET=1000000
